#!/bin/sh
set -eu

remote_name="$1"
remote_url="$2"

case "$remote_name:$remote_url" in
  private:*|*:https://github.com/github653224/DeepSeekBalanceMonitorForMac-private.git)
    exit 0
    ;;
esac

has_blocked_paths() {
  git diff --name-only "$1" "$2" -- README.local.md 'docs/*.md' | grep . >/dev/null 2>&1
}

while read -r local_ref local_sha remote_ref remote_sha
do
  [ -z "${local_ref:-}" ] && continue

  case "$local_sha" in
    0000000000000000000000000000000000000000)
      continue
      ;;
  esac

  case "$remote_sha" in
    0000000000000000000000000000000000000000)
      if git ls-tree -r --name-only "$local_sha" -- README.local.md 'docs/*.md' | grep . >/dev/null 2>&1; then
        echo "[pre-push] 阻止向公开仓库推送私有文件：README.local.md 或 docs/*.md" >&2
        echo "[pre-push] 如需推送私有资料，请切换到 private-docs 分支并推送到 private 远程。" >&2
        exit 1
      fi
      ;;
    *)
      if has_blocked_paths "$remote_sha" "$local_sha"; then
        echo "[pre-push] 阻止向公开仓库推送私有文件：README.local.md 或 docs/*.md" >&2
        echo "[pre-push] 如需推送私有资料，请切换到 private-docs 分支并推送到 private 远程。" >&2
        exit 1
      fi
      ;;
  esac
done

exit 0
